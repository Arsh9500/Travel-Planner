rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // User profiles
    match /users/{userId} {
      allow create: if isSignedIn() && request.auth.uid == userId;

      // Admin can read any user; user can read own profile
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      // Admin can update any profile; user can update own profile but cannot change role
      allow update: if isAdmin() ||
        (isSignedIn() && request.auth.uid == userId && request.resource.data.role == resource.data.role);

      allow delete: if isAdmin();
    }

    // Users can only read/write their own wishlist doc: wishlists/{uid}
    match /wishlists/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Shared group itineraries. Owners and invited collaborator emails can read/edit.
    match /groupTrips/{tripId} {
      function isGroupMember() {
        return isSignedIn() &&
          (resource.data.ownerUid == request.auth.uid ||
            request.auth.token.email in resource.data.collaboratorEmails);
      }

      allow read: if isGroupMember();

      allow create: if isSignedIn() &&
        request.resource.data.ownerUid == request.auth.uid &&
        request.auth.token.email in request.resource.data.editorEmails;

      allow update: if isGroupMember() &&
        request.resource.data.ownerUid == resource.data.ownerUid;

      allow delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
